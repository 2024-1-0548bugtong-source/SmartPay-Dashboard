{
  "version": 2,
  "installCommand": "cd SmartPay-Dashboard && npx pnpm@10.33.0 install --no-frozen-lockfile",
  "buildCommand": "cd SmartPay-Dashboard && npx pnpm@10.33.0 --filter @workspace/smartpay-dashboard run build",
  "outputDirectory": "SmartPay-Dashboard/artifacts/smartpay-dashboard/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
